pipeline {
    agent any
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Terraform Operations') {
            steps {
                // Using 'jenkins-creds' to match your Global Credentials list
                withAWS(credentials: 'jenkins-creds', region: 'us-east-1') {
                    dir('Week28') {
                        sh 'terraform init'
                        sh 'terraform fmt'
                        sh 'terraform validate'
                        sh 'terraform destroy --auto-approve'
                    }
                }
            }
        }
    }
}